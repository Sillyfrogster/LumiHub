# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumihub

# Server options
PORT=3000
NODE_ENV=development
SECRET=secret

# File Storage
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=5242880

# NSFW Detection
NSFW_THRESHOLD=0.6

# Discord OAuth
DISCORD_CLIENT_ID=1485359841684885666
DISCORD_SECRET_ID=
DISCORD_REDIRECT_URL=http://localhost:5173/api/v1/auth/discord/callback
DISCORD_AUTH_URL=https://discord.com/oauth2/authorize?

# Moderation — comma-separated Discord user IDs granted moderator role
MODERATOR_DISCORD_IDS=